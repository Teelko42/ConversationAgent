        "remove_node_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "remove_edge_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "snapshot_offer": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "session_id",
        "delta_seq"
      ],
      "additionalProperties": false
    }
