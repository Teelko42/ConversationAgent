                  "type": "string"
                }
              },
              "salience": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "degree": {
                "type": "integer",
                "minimum": 0
              },
              "first_seen_segment_id": {
                "type": "string"
              },
              "first_seen_t_us": {
                "type": "integer",
                "minimum": 0
              },
              "last_seen_t_us": {
                "type": "integer",
                "minimum": 0
              },
              "embedding_ref": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "consent_class": {
                "type": "string",
                "enum": [
                  "standard",
                  "sensitive"
                ]
              }
            },
            "required": [
              "id",
              "revision",
              "session_id",
              "tenant_id",
              "label",
              "node_type",
              "concept_card_id",
              "consent_class"
            ],
            "additionalProperties": false
          },
          "default": []
