{
  "$ref": "#/definitions/transcript_segment",
  "definitions": {
    "transcript_segment": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string",
          "format": "uuid"
        },
        "session_id": {
          "type": "string",
          "format": "uuid"
        },
        "seq": {
          "type": "integer",
          "minimum": 0
        },
        "producer_id": {
          "type": "string",
          "minLength": 1
        },
        "emitted_at": {
          "type": "integer"
        },
        "segment_id": {
          "type": "string"
        },
        "rev": {
          "type": "integer",
          "minimum": 0
        },
        "is_final": {
          "type": "boolean"
        },
        "supersedes": {
          "type": [
            "string",
            "null"
          ]
        },
        "start_ms": {
          "type": "integer",
          "minimum": 0
        },
        "end_ms": {
          "type": "integer",
          "minimum": 0
        },
        "session_start_at": {
          "type": "integer"
        },
        "text": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "language_confidence": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "words": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "w": {
                "type": "string"
              },
              "start_ms": {
                "type": "integer",
                "minimum": 0
              },
              "end_ms": {
                "type": "integer",
                "minimum": 0
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "speaker_id": {
                "type": "string"
              },
              "is_domain_term": {
                "type": "boolean"
              },
              "alt": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "w",
              "start_ms",
              "end_ms",
              "confidence",
              "speaker_id",
              "is_domain_term",
              "alt"
            ],
            "additionalProperties": false
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_band": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "no_speech_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "speaker": {
          "type": "object",
          "properties": {
            "speaker_id": {
              "type": "string"
            },
            "speaker_confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "participant_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "display_name": {
              "type": "string"
            },
            "channel_role": {
              "type": "string"
            },
            "is_overlap": {
              "type": "boolean"
            },
            "diarization_method": {
              "type": "string"
            }
          },
          "required": [
            "speaker_id",
            "speaker_confidence",
            "participant_id",
            "display_name",
            "channel_role",
            "is_overlap",
            "diarization_method"
          ],
          "additionalProperties": false
        },
        "domain_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": {
                "type": "string"
              },
              "canonical": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "char_start": {
                "type": "integer",
                "minimum": 0
              },
              "char_end": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "term",
              "canonical",
              "source",
              "char_start",
              "char_end"
            ],
            "additionalProperties": false
          }
        },
        "timing_meta": {
          "type": "object",
          "properties": {
            "first_partial_at": {
              "type": "integer"
            },
            "final_at": {
              "type": "integer"
            },
            "audio_end_to_partial_ms": {
              "type": "integer",
              "minimum": 0
            },
            "audio_end_to_final_ms": {
              "type": "integer",
              "minimum": 0
            },
            "rtf": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": [
            "first_partial_at",
            "final_at",
            "audio_end_to_partial_ms",
            "audio_end_to_final_ms",
            "rtf"
          ],
          "additionalProperties": false
        },
        "frame_seq_range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": [
            {
              "type": "integer"
            },
            {
              "type": "integer"
            }
          ]
        },
        "corrected_by": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "endpointer",
                "llm_postedit",
                "user"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "consent": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "store_audio",
                "no_audio_retention",
                "transcript_only"
              ]
            },
            "consent_id": {
              "type": "string"
            },
            "pii_redacted": {
              "type": "boolean"
            }
          },
          "required": [
            "mode",
            "consent_id",
            "pii_redacted"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "tenant_id",
        "session_id",
        "seq",
        "producer_id",
        "emitted_at",
        "segment_id",
        "rev",
        "is_final",
        "supersedes",
        "start_ms",
        "end_ms",
        "session_start_at",
        "text",
        "language",
        "confidence",
        "confidence_band",
        "speaker",
        "consent"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
