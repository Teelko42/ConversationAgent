{
  "$ref": "#/definitions/kg_delta",
  "definitions": {
    "kg_delta": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string",
          "format": "uuid"
        },
        "delta_seq": {
          "type": "integer",
