        "upsert_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "revision": {
                "type": "integer",
                "minimum": 0
              },
              "session_id": {
                "type": "string",
                "format": "uuid"
              },
              "tenant_id": {
                "type": "string",
                "format": "uuid"
              },
              "label": {
                "type": "string"
              },
              "node_type": {
                "type": "string",
                "enum": [
                  "concept",
                  "topic",
                  "entity",
                  "speaker",
                  "insight",
                  "document",
                  "event"
                ]
              },
              "concept_card_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "domain": {
                "type": "string"
              },
              "aliases": {
                "type": "array",
