{
  "name": "@aizen/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Canonical Aizen data contracts (D06) as zod schemas + inferred types, with JSON Schema export for the registry / non-TS consumers.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "export-schema": "node --import tsx scripts/export-schema.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "zod-to-json-schema": "^3.23.1"
  }
}
