.claudetrees/
.claude/

# Secrets — real keys live in .env, which must NEVER be committed.
# .env.example is the safe, committed template (placeholders only).
.env
.env.*
!.env.example

# Node / TypeScript
node_modules/
dist/
*.tsbuildinfo
.vitest/
coverage/
*.log
.DS_Store

# Generated JSON Schema is committed (it's the registry artifact); build output is not

# Terraform (infra/)
.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfvars
!example.tfvars
.terraform.lock.hcl
