{
  "$ref": "#/definitions/source_quota_status",
  "definitions": {
    "source_quota_status": {
      "type": "object",
      "properties": {
        "tier": {
          "type": "string",
          "enum": [
            "free",
            "pro",
            "team",
            "enterprise"
          ]
        },
        "used_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "limit_bytes": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "retention_window_days": {
          "anyOf": [
            {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "exceeded": {
          "type": "boolean"
        }
      },
      "required": [
        "tier",
        "used_bytes",
        "limit_bytes",
        "count",
        "retention_window_days",
        "exceeded"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
