            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "revision": {
                "type": "integer",
                "minimum": 0
              },
              "session_id": {
                "type": "string",
                "format": "uuid"
              },
              "tenant_id": {
                "type": "string",
                "format": "uuid"
              },
              "src": {
                "type": "string"
              },
              "dst": {
                "type": "string"
              },
              "relation": {
                "type": "string",
                "enum": [
                  "mentions",
                  "discusses",
                  "defines",
                  "is_a",
                  "part_of",
                  "causes",
                  "depends_on",
                  "contrasts_with",
                  "example_of",
                  "attributed_to",
                  "decided_by",
                  "raised_by",
                  "references",
                  "temporal_follows",
                  "same_as",
                  "related_to"
                ]
              },
              "directed": {
                "type": "boolean"
              },
              "weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
